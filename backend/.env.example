# FreightWatch Backend — Environment Configuration
# Copy to .env and fill in your values.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
DEBUG=false

# ── Database (Supabase Supavisor Session Mode Pooler) ─────────────────────────
# Format: postgresql+asyncpg://<user>.<project-ref>@<pooler-host>:5432/postgres
DATABASE_URL=postgresql+asyncpg://freightwatch_app.jvucxzrsiqzcaojnpazu@aws-1-eu-west-1.pooler.supabase.com:5432/postgres
DB_SSL_REQUIRED=true
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# ── Authentication ─────────────────────────────────────────────────────────────
JWT_AUTH_ENABLED=true
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=INSECURE_DEFAULT_SECRET_CHANGE_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=90

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VISION_MODEL=claude-sonnet-4-6

# ── Business Rules ────────────────────────────────────────────────────────────
BENCHMARK_TOLERANCE_PCT=5.0        # ±5% → 'im_markt' classification
INVOICE_TOTAL_TOLERANCE_PCT=2.0    # Invoice total rounding tolerance
UPLOAD_PROCESSING_CONCURRENCY=5    # Max concurrent benchmark calculations
MAX_UPLOAD_SIZE_MB=10

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated or JSON array
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json    # json | console
LOG_FILE=logs/freightwatch.log     # relative to backend/ working dir
LOG_FILE_MAX_MB=10                 # rotate at this size; 0 to disable file logging
LOG_FILE_BACKUP_COUNT=7            # rotated files to keep (~70 MB total)

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_ENABLED=false
# SENTRY_DSN=https://...@sentry.io/...
